# Optional. Required if your HyperSync plan enforces auth.
ENVIO_API_TOKEN=

# Postgres used by Envio + Hasura
ENVIO_POSTGRES_PASSWORD=postgres
ENVIO_PG_USER=postgres
ENVIO_PG_DATABASE=postgres

# Hasura admin secret
HASURA_GRAPHQL_ADMIN_SECRET=myadminsecretkey
HASURA_GRAPHQL_UNAUTHORIZED_ROLE=public

# Optional (used by `pnpm setup-public`)
# local metadata endpoint (default fallback)
# HASURA_ENDPOINT=http://127.0.0.1:8080/v1/metadata
# or public domain:
# HASURA_ENDPOINT=https://your-domain/v1/metadata
HASURA_ROLE=public
HASURA_SOURCE=default

# Exposed ports on host
HASURA_EXTERNAL_PORT=8080
INDEXER_EXTERNAL_PORT=8081

# Indexer runtime
CONFIG_FILE=config.yaml
LOG_LEVEL=info

# Optional: only needed if Abstract profile endpoint is gated in your runtime
ABS_PROFILE_BEARER=
